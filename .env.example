# Stripe test/live keys. Do not put real secrets in Git.
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=eur

# SMTP account used by both backends to send reset and purchase emails.
# Gmail requires an App Password, not your normal account password.
APP_RESET_FRONTEND_URL=http://localhost:4200/reset-password
APP_MAIL_FROM=
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_STARTTLS_ENABLE=true
SPRING_MAIL_STARTTLS_REQUIRED=true
